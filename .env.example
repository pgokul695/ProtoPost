# ProtoPost Email Gateway — Environment Variables
# Copy this file to .env and fill in values.
# Most configuration is handled via the dashboard UI, not this file.
# These variables are optional — the server runs fine without any of them.

# ─────────────────────────────
# Server settings
# ─────────────────────────────

# Port to listen on (default: 8000)
PORT=8000

# Host to bind to (default: 127.0.0.1 — localhost only)
# Set to 0.0.0.0 to allow connections from the network (e.g. on a cloud VM)
HOST=127.0.0.1

# ─────────────────────────────
# File paths
# ─────────────────────────────

# Path to the configuration file (default: ./config.json)
CONFIG_PATH=./config.json

# Path to the SQLite database file (default: ./emails.db)
DATABASE_PATH=./emails.db

# ─────────────────────────────
# Logging
# ─────────────────────────────

# Log level: debug | info | warning | error (default: info)
LOG_LEVEL=info

# ─────────────────────────────
# CORS
# ─────────────────────────────

# Allowed CORS origins (comma-separated).
# Default: all origins allowed (*) — suitable for local development.
# Restrict this if you're running the gateway on a shared or public server.
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────
# Authentication
# ─────────────────────────────

# Optional bearer token to protect all /api/* endpoints.
# Leave unset (default) for no auth — recommended for local development.
# Set to any secret string when hosting publicly on Render, Railway, etc.
# The dashboard stores this token in localStorage and sends it automatically.
# Generate a secure token: openssl rand -hex 16
# AUTH_TOKEN=your-secret-token-here

# ─────────────────────────────
# Pre-seeded provider credentials (optional)
# ─────────────────────────────
# These let you configure credentials without using the dashboard.
# Remove the leading # from any variable you want to use.
# Note: credentials set via the dashboard always take precedence once saved.

# Resend API key
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mailtrap API token (Email Sending, not Email Testing)
# MAILTRAP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gmail address and App Password
# GMAIL_ADDRESS=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Custom SMTP settings
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your_username
# SMTP_PASSWORD=your_password
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
